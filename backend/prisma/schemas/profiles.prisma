// Subcategory table from users only for students
model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  completedHours Int @default(0)

  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id])

  bookedLessons    TimeSlot[]
  completedLessons StudentLesson[]
  studentBlockouts StudentBlockout[]

  @@map("student_profiles")
}

// Subcategory table from users only for instructors
model InstructorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  students              StudentProfile[]
  availabilityTemplates AvailabilityTemplate[]
  instructorBlockouts   InstructorBlockout[]
  timeSlots             TimeSlot[]

  @@map("instructor_profiles")
}
