// The driving school
model School {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  address   String
  phone     String
  users     User[]
  cars      Car[]

  @@map("schools")
}

// The driving school cars
model Car {
  id                 String   @id @default(uuid())
  licensePlate       String
  isAvailable        Boolean
  PTIExpireDate      DateTime
  vignetteExpireDate DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  @@map("cars")
}
