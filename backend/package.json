{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "seed:roles": "tsx src/scripts/seed-role-profiles.ts",
    "db:recreate": "tsx src/scripts/db-recreate.ts",
    "db:migrate": "tsx src/scripts/db-migrate.ts",
    "db:nuke": "tsx src/scripts/db-nuke.ts",
    "db:generate": "tsx src/scripts/db-generate.ts",
    "db:refresh": "npm run db:nuke && npm run db:generate && npm run db:migrate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@infisical/sdk": "^5.0.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/web-push": "^3.6.4",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.6",
    "@smithy/util-defaults-mode-node": "3.0.34",
    "@smithy/config-resolver": "4.4.0",
    "esbuild": "^0.25.0"
  }
}
