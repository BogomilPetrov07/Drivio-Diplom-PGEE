{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/server.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "db:recreate": "tsx src/scripts/db-recreate.ts",
    "db:migrate": "tsx src/scripts/db-migrate.ts"
  },
  "dependencies": {
    "@infisical/sdk": "^5.0.0",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/web-push": "^3.6.4",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.6",
    "@smithy/util-defaults-mode-node": "3.0.34",
    "@smithy/config-resolver": "4.4.0",
    "esbuild": "^0.25.0"
  }
}
