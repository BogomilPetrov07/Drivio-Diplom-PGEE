{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022","DOM"],
    "jsx": "react-jsx",
    "rootDir": "./",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true
  },
  "include": ["src/**/*","drizzle.config.ts","drizzle/schemas/**/*"],
  "exclude": ["node_modules","**/*.test.ts"]
}