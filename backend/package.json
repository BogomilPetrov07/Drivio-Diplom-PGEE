{
  "name": "backend",
  "version": "1.0.0",
  "description": "Drivio main backend",
  "main": "src/server.ts",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "build": "npm install && tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",

    "drizzle": "infisical run --path=/backend --path=/backend/DB -- tsx ./node_modules/drizzle-kit/bin.cjs",
    "drizzle:stage": "infisical run --env=staging --path=/backend --path=/backend/DB -- tsx ./node_modules/drizzle-kit/bin.cjs",

    "db:generate": "npm run drizzle -- generate",
    "db:push": "npm run drizzle -- push",
    "db:migrate": "npm run drizzle -- migrate",
    "db:drop": "npm run drizzle -- drop",

    "stage:generate": "npm run drizzle:stage -- generate",
    "stage:push": "npm run drizzle:stage -- push",
    "stage:migrate": "npm run drizzle:stage -- migrate",
    "stage:drop": "npm run drizzle:stage -- drop",

    "db:reset:dev": "infisical run --path=/backend --path=/backend/DB -- tsx ./src/scripts/drop-types.ts && npm run db:generate && npm run db:migrate",
    "db:reset:stage": "infisical run --env=staging --path=/backend --path=/backend/DB -- tsx ./src/scripts/drop-types.ts && npm run stage:generate && npm run stage:migrate"
  },
  "dependencies": {
    "@infisical/sdk": "^4.0.5",
    "@react-email/components": "^1.0.3",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.18.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.7",
    "drizzle-kit": "^0.31.9",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typesync": "^0.14.3"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.6",
    "@smithy/util-defaults-mode-node": "3.0.34",
    "@smithy/config-resolver": "4.4.0",
    "esbuild": "^0.25.0"
  }
}